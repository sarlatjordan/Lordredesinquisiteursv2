# Supabase — copier dans .env.local et remplir avec vos vraies valeurs
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Optionnel : clé service pour les opérations admin côté serveur uniquement
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# URL de l'application (utilisé pour les callbacks OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile — anti-spam formulaire candidature public
# Obtenir les clés prod : https://dash.cloudflare.com → Turnstile → Add a site
# Clés de test pour dev local (always pass) :
#   sitekey : 1x00000000000000000000AA
#   secret  : 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
